#############################################
# Order-only phony target for bootloader

build cmake_object_order_depends_target_bootloader: phony || cmake_object_order_depends_target_STM32_Drivers

build CMakeFiles/bootloader.dir/Bootloader/Src/main.c.obj: C_COMPILER__bootloader_unscanned_Debug E$:/ST/STM32/MY_workspace/Projects_F407/MY_OTA_GUI/Bootloader/Src/main.c || cmake_object_order_depends_target_bootloader
  CONFIG = Debug
  DEFINES = -DDEBUG -DLFS_READONLY -DSTM32F407xx -DUSE_HAL_DRIVER
